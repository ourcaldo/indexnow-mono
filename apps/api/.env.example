# ============================================
# API APP (.env) — Backend / API server
# ============================================

# ── Core ──
NODE_ENV=development
PORT=3001
NEXT_PUBLIC_BASE_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=IndexNow Studio
NEXT_PUBLIC_APP_URL=http://localhost:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api
NEXT_PUBLIC_BACKEND_URL=http://localhost:3002
NEXT_PUBLIC_DASHBOARD_URL=http://localhost:3000
WORKER_MODE=false
MAINTENANCE_MODE=false

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key          # Required in production
SUPABASE_JWT_SECRET=your-jwt-secret                      # Required in production
SUPABASE_BUCKET_NAME=indexnow-public

# ── Security (all required in production) ──
ENCRYPTION_KEY=your-32-character-encryption-key!
ENCRYPTION_MASTER_KEY=your-64-character-hex-master-key-here-replace-me-with-real-value!!
SYSTEM_API_KEY=your-system-api-key
JWT_SECRET=your-jwt-secret
API_SIGNATURE_SECRET=your-api-signature-secret
REVALIDATE_SECRET=your-revalidate-secret
ADMIN_EMAIL=admin@your-domain.com

# ── Redis & BullMQ ──
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USER=
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379
ENABLE_BULLMQ=true
BULL_BOARD_USERNAME=admin
BULL_BOARD_PASSWORD=admin

BULLMQ_CONCURRENCY_RANK_CHECK=5
BULLMQ_CONCURRENCY_EMAIL=10
BULLMQ_CONCURRENCY_PAYMENTS=3
BULLMQ_RATE_LIMIT_RANK_CHECK_MAX=28
BULLMQ_RATE_LIMIT_RANK_CHECK_DURATION=60000
BULLMQ_RATE_LIMIT_EMAIL_MAX=50
BULLMQ_RATE_LIMIT_EMAIL_DURATION=60000

# ── Email (SMTP) ──
SMTP_HOST=smtp.your-mail-provider.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@your-domain.com
SMTP_PASS=your-smtp-password
SMTP_FROM_NAME=IndexNow Studio
SMTP_FROM_EMAIL=noreply@your-domain.com

# ── Paddle Payment Gateway (API key & webhook secret stored in DB via admin panel) ──
PADDLE_PORTAL_ENABLED=true
PADDLE_SUBSCRIPTION_UPDATE_ENABLED=true
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...
NEXT_PUBLIC_PADDLE_ENV=sandbox

# ── SE Ranking (optional) ──
SE_RANKING_API_KEY=
SE_RANKING_API_URL=https://api4.seranking.com

# ── Monitoring & Analytics ──
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACE_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_ERROR_RATE=1.0
SENTRY_ORG_AUTH_TOKEN=                                    # Organization token (sntrys_...) for source map uploads during build
SENTRY_INTEGRATION_TOKEN=                                  # Internal Integration token for runtime Sentry REST API calls
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_WEBHOOK_SECRET=                                   # Optional: Sentry webhook signature verification
LOG_LEVEL=info
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_CONTAINER_ID=
NEXT_PUBLIC_CUSTOMERIO_SITE_ID=
NEXT_PUBLIC_ANALYTICS_DEBUG=false
