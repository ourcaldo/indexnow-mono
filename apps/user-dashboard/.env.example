# ============================================
# USER DASHBOARD APP (.env) — End-user frontend
# ============================================
# The user dashboard only needs Supabase client keys,
# Paddle client token, and monitoring config.
# It does NOT need server secrets.

# ── Core ──
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=IndexNow Studio
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# ── Supabase (client-side only) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── Paddle (client-side only, for checkout) ──
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=test_...
NEXT_PUBLIC_PADDLE_ENV=sandbox

# ── Monitoring & Analytics (optional) ──
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACE_SAMPLE_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_SESSION_RATE=0.1
NEXT_PUBLIC_SENTRY_REPLAYS_ERROR_RATE=1.0
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GTM_CONTAINER_ID=
NEXT_PUBLIC_CUSTOMERIO_SITE_ID=
NEXT_PUBLIC_ANALYTICS_DEBUG=true
