{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "SUPABASE_URL",
    "SUPABASE_ANON_KEY",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_JWT_SECRET",
    "SUPABASE_BUCKET_NAME",

    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "NEXT_PUBLIC_SENTRY_DSN",

    "SENTRY_DSN",
    "SENTRY_ORG",
    "SENTRY_PROJECT",
    "SENTRY_ORG_AUTH_TOKEN",
    "SENTRY_INTEGRATION_TOKEN",
    "SENTRY_WEBHOOK_SECRET",
    "SENTRY_SUPPRESS_TURBOPACK_WARNING",

    "ENCRYPTION_KEY",
    "ENCRYPTION_MASTER_KEY",
    "JWT_SECRET",
    "SYSTEM_API_KEY",
    "ALLOWED_ORIGINS",

    "REDIS_HOST",
    "REDIS_PORT",
    "REDIS_PASSWORD",
    "REDIS_USER",
    "REDIS_URL",

    "SMTP_HOST",
    "SMTP_PORT",
    "SMTP_USER",
    "SMTP_PASS",
    "SMTP_FROM_NAME",
    "SMTP_FROM_EMAIL",
    "SMTP_SECURE",

    "ENABLE_BULLMQ",
    "WORKER_MODE",
    "BULL_BOARD_USERNAME",
    "BULL_BOARD_PASSWORD",
    "BULLMQ_CONCURRENCY_RANK_CHECK",
    "BULLMQ_CONCURRENCY_EMAIL",
    "BULLMQ_CONCURRENCY_PAYMENTS",
    "BULLMQ_RATE_LIMIT_RANK_CHECK_MAX",
    "BULLMQ_RATE_LIMIT_RANK_CHECK_DURATION",
    "BULLMQ_RATE_LIMIT_EMAIL_MAX",
    "BULLMQ_RATE_LIMIT_EMAIL_DURATION",

    "PADDLE_PORTAL_ENABLED",
    "PADDLE_SUBSCRIPTION_UPDATE_ENABLED",

    "PORT",
    "LOG_LEVEL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json", "package.json", "next.config.ts", "tsup.config.ts"],
      "outputs": ["dist/**", ".next/**"],
      "env": ["NODE_ENV", "NEXT_PUBLIC_*"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "*.config.*"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tests/**", "vitest.config.*"],
      "outputs": [],
      "env": ["NODE_ENV"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig.json"],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
